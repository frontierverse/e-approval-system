generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DocumentStatus {
  DRAFT
  SUBMITTED
  IN_PROGRESS
  APPROVED
  REJECTED
  RECALLED
}

enum ApprovalStepStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum AuditAction {
  CREATE_DRAFT
  UPDATE_DRAFT
  DELETE_DRAFT
  SUBMIT
  APPROVE
  PROXY_APPROVE
  PROXY_REJECT
  REJECT
  RECALL
  COMPLETE
  CREATE_USER
  UPDATE_USER
  CREATE_DEPARTMENT
  UPDATE_DEPARTMENT
  CREATE_POSITION
  UPDATE_POSITION
  CREATE_TEMPLATE
  UPDATE_TEMPLATE
  UPDATE_ATTACHMENT_POLICY
  UPDATE_COMPANY_INFO
  CHANGE_PASSWORD
  CREATE_RESOURCE
  UPDATE_RESOURCE
  DELETE_RESOURCE
  UPDATE_WORK_SCHEDULE
  UPDATE_CAFE_ITEM
  CREATE_YOUTH
  UPDATE_YOUTH
  UPDATE_YOUTH_NOTE
  DELETE_YOUTH_NOTE
}

enum NotificationType {
  APPROVAL_REQUESTED
  APPROVAL_APPROVED
  APPROVAL_REJECTED
  APPROVAL_COMPLETED
}

model User {
  id                            String     @id @default(cuid())
  name                          String
  email                         String?    @unique
  passwordHash                  String?
  role                          UserRole   @default(USER)
  status                        UserStatus @default(ACTIVE)
  birthDate                     String?
  hireDate                      String?
  resignationDate               String?
  profileImageStorageProvider   String?
  profileImageStorageKey        String?
  profileImageMimeType          String?
  profileImageSize              Int?
  profileImageUpdatedAt         DateTime?
  signatureImageStorageProvider String?
  signatureImageStorageKey      String?
  signatureImageMimeType        String?
  signatureImageSize            Int?
  signatureImageUpdatedAt       DateTime?
  createdAt                     DateTime   @default(now())
  updatedAt                     DateTime   @updatedAt

  departmentId String
  positionId   String

  department Department @relation(fields: [departmentId], references: [id])
  position   Position   @relation(fields: [positionId], references: [id])

  draftedDocuments     ApprovalDocument[]   @relation("DocumentDrafter")
  approvalSteps        ApprovalStep[]       @relation("StepApprover")
  actedApprovalSteps   ApprovalStep[]       @relation("StepActor")
  proxyApprovalSteps   ApprovalStep[]       @relation("StepProxyApprover")
  comments             ApprovalComment[]    @relation("CommentAuthor")
  attachments          Attachment[]         @relation("AttachmentUploader")
  resourcePosts        ResourcePost[]       @relation("ResourceAuthor")
  resourceAttachments  ResourceAttachment[] @relation("ResourceAttachmentUploader")
  resourcePostViews    ResourcePostView[]   @relation("ResourcePostViewUser")
  auditLogs            AuditLog[]           @relation("AuditActor")
  loginHistories       LoginHistory[]
  notifications        Notification[]
  signedAttachments    Attachment[]         @relation("AttachmentSigner")
  convertedAttachments Attachment[]         @relation("AttachmentConverter")
  leaveLedgerEntries   StaffLeaveLedger[]   @relation("StaffLeaveUser")
  createdLeaveEntries  StaffLeaveLedger[]   @relation("StaffLeaveActor")

  @@index([departmentId])
  @@index([positionId])
  @@index([birthDate])
  @@index([hireDate])
  @@index([resignationDate])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Department?  @relation("DepartmentChildren", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentChildren")
  users    User[]

  @@index([parentId])
}

model Position {
  id        String   @id @default(cuid())
  name      String
  level     Int
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  schema      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents ApprovalDocument[]
}

model AttachmentPolicy {
  id                String   @id
  maxFileCount      Int      @default(10)
  maxFileSizeMb     Int      @default(30)
  allowedExtensions Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CompanyBusinessInfo {
  id                 String   @id
  registrationNumber String?
  address            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ApprovalDocument {
  id          String         @id @default(cuid())
  documentNo  String?        @unique
  title       String
  category    String         @default("일반")
  content     String
  status      DocumentStatus @default(DRAFT)
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  templateId String
  drafterId  String

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  drafter  User             @relation("DocumentDrafter", fields: [drafterId], references: [id])

  approvalSteps ApprovalStep[]
  comments      ApprovalComment[]
  attachments   Attachment[]
  auditLogs     AuditLog[]
  notifications Notification[]
  leaveLedgerEntries StaffLeaveLedger[]

  @@index([status])
  @@index([templateId])
  @@index([drafterId])
  @@index([submittedAt])
}

model ApprovalStep {
  id                String             @id @default(cuid())
  order             Int
  status            ApprovalStepStatus @default(WAITING)
  actedAt           DateTime?
  comment           String?
  decisionType      String             @default("NORMAL")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  documentId        String
  approverId        String
  actedById         String?
  proxyApprovedById String?

  document        ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approver        User             @relation("StepApprover", fields: [approverId], references: [id])
  actedBy         User?            @relation("StepActor", fields: [actedById], references: [id], onDelete: SetNull)
  proxyApprovedBy User?            @relation("StepProxyApprover", fields: [proxyApprovedById], references: [id], onDelete: SetNull)

  @@unique([documentId, order])
  @@unique([documentId, approverId])
  @@index([approverId])
  @@index([actedById])
  @@index([proxyApprovedById])
  @@index([status])
}

model ApprovalComment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentId String
  authorId   String

  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User             @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([documentId])
  @@index([authorId])
}

model Attachment {
  id              String    @id @default(cuid())
  originalName    String
  storageProvider String    @default("local")
  storageKey      String
  mimeType        String
  size            Int
  createdAt       DateTime  @default(now())
  signedAt        DateTime?
  convertedAt     DateTime?

  documentId                  String
  uploaderId                  String
  signedSourceAttachmentId    String?
  signedById                  String?
  convertedSourceAttachmentId String?
  convertedById               String?

  document                  ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploader                  User             @relation("AttachmentUploader", fields: [uploaderId], references: [id])
  signedBy                  User?            @relation("AttachmentSigner", fields: [signedById], references: [id], onDelete: SetNull)
  signedSourceAttachment    Attachment?      @relation("AttachmentSignedCopies", fields: [signedSourceAttachmentId], references: [id], onDelete: SetNull)
  signedCopies              Attachment[]     @relation("AttachmentSignedCopies")
  convertedBy               User?            @relation("AttachmentConverter", fields: [convertedById], references: [id], onDelete: SetNull)
  convertedSourceAttachment Attachment?      @relation("AttachmentConvertedCopies", fields: [convertedSourceAttachmentId], references: [id], onDelete: SetNull)
  convertedCopies           Attachment[]     @relation("AttachmentConvertedCopies")

  @@index([documentId])
  @@index([uploaderId])
  @@index([signedById])
  @@index([signedSourceAttachmentId])
  @@index([convertedById])
  @@index([convertedSourceAttachmentId])
}

model ResourcePost {
  id        String   @id @default(cuid())
  title     String
  summary   String
  category  String   @default("bajaul")
  educationLevel String?
  pinned    Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String

  author User @relation("ResourceAuthor", fields: [authorId], references: [id])

  attachments ResourceAttachment[]
  views       ResourcePostView[]

  @@index([authorId])
  @@index([category])
  @@index([category, educationLevel])
  @@index([createdAt])
  @@index([pinned, createdAt])
}

model ResourceAttachment {
  id              String   @id @default(cuid())
  originalName    String
  storageProvider String   @default("local")
  storageKey      String
  mimeType        String
  size            Int
  createdAt       DateTime @default(now())

  resourceId String
  uploaderId String

  resource ResourcePost @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  uploader User         @relation("ResourceAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([resourceId])
  @@index([uploaderId])
}

model ResourcePostView {
  id            String   @id @default(cuid())
  firstViewedAt DateTime @default(now())
  lastViewedAt  DateTime @default(now())
  viewCount     Int      @default(1)

  resourceId String
  userId     String

  resource ResourcePost @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user     User         @relation("ResourcePostViewUser", fields: [userId], references: [id])

  @@unique([resourceId, userId])
  @@index([resourceId])
  @@index([userId])
  @@index([lastViewedAt])
}

model Youth {
  id            String   @id @default(cuid())
  name          String   @unique
  admissionDate String?
  dischargeDate String?
  birthDate     String?
  age           Int?
  phone         String?
  familyContact String?
  familyRelationship String?
  familyPhone        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  familyContacts YouthFamilyContact[]
  notes          YouthSpecialNote[]
  learningSchedules YouthLearningSchedule[]
  rules          YouthRule[]

  @@index([name])
  @@index([birthDate])
  @@index([dischargeDate])
}

model YouthRule {
  id            String   @id @default(cuid())
  category      String
  detail        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  targetYouthId String?

  targetYouth Youth? @relation(fields: [targetYouthId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([createdAt])
  @@index([targetYouthId])
}

model YouthFamilyContact {
  id           String   @id @default(cuid())
  relationship String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  youthId String

  youth Youth @relation(fields: [youthId], references: [id], onDelete: Cascade)

  @@index([youthId])
  @@index([relationship])
}

model YouthSpecialNote {
  id         String   @id @default(cuid())
  title      String
  summary    String
  detail     String
  category   String
  recordedAt String
  author     String
  priority   String   @default("보통")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  youthId String

  youth Youth @relation(fields: [youthId], references: [id], onDelete: Cascade)

  @@index([youthId])
  @@index([category])
  @@index([priority])
  @@index([recordedAt])
}

model YouthLearningSchedule {
  id           String   @id @default(cuid())
  scheduleDate String
  startHour    Int
  startMinute  Int
  endHour      Int
  endMinute    Int
  content      String
  repeatsWeekly Boolean  @default(false)
  recurrenceSourceDate String?
  recurrenceWeekdays String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  youthId String

  youth Youth @relation(fields: [youthId], references: [id], onDelete: Cascade)

  @@unique([youthId, scheduleDate, startMinute])
  @@index([scheduleDate, startMinute])
  @@index([repeatsWeekly, scheduleDate])
  @@index([recurrenceSourceDate])
  @@index([recurrenceWeekdays])
  @@index([startHour])
  @@index([startMinute])
}

model YouthCommonSchedule {
  id          String   @id @default(cuid())
  weekday     Int
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([weekday, startMinute])
  @@index([weekday, startMinute])
  @@index([startHour])
  @@index([startMinute])
}

model WorkSchedule {
  id          String   @id @default(cuid())
  scheduleDate String
  weekday     Int
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scheduleDate, startMinute])
  @@index([scheduleDate, startMinute])
  @@index([weekday, startMinute])
  @@index([startHour])
  @@index([startMinute])
}

model CafeItem {
  id             String   @id @default(cuid())
  name           String
  category       String
  purchasedAt    DateTime @db.Date
  priceWon       Int?
  purchaseReason String?
  expirationDate DateTime? @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([purchasedAt])
  @@index([expirationDate])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  targetType String
  targetId   String
  message    String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  country    String?
  region     String?
  city       String?
  createdAt  DateTime    @default(now())

  actorId    String
  documentId String?

  actor    User              @relation("AuditActor", fields: [actorId], references: [id])
  document ApprovalDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([documentId])
  @@index([action])
  @@index([createdAt])
}

model LoginHistory {
  id            String   @id @default(cuid())
  attemptedName String
  success       Boolean
  failureReason String?
  ipAddress     String?
  userAgent     String?
  browser       String?
  os            String?
  device        String?
  country       String?
  region        String?
  city          String?
  createdAt     DateTime @default(now())

  userId String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([attemptedName])
  @@index([success, createdAt])
  @@index([createdAt])
}

model StaffLeaveLedger {
  id             String   @id @default(cuid())
  entryType      String
  sourceKey      String?
  eventDate      String
  amountHalfDays Int
  reason         String?
  createdAt      DateTime @default(now())

  userId     String
  actorId    String?
  documentId String?

  user     User              @relation("StaffLeaveUser", fields: [userId], references: [id], onDelete: Cascade)
  actor    User?             @relation("StaffLeaveActor", fields: [actorId], references: [id], onDelete: SetNull)
  document ApprovalDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceKey])
  @@unique([documentId])
  @@index([userId, eventDate])
  @@index([entryType])
  @@index([actorId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  userId     String
  documentId String

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  document ApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([documentId])
  @@index([type])
}
